# [LINEAR DIVISION] Drum-Trigger Git Shield
# Prevent corruption by excluding heavy binaries and local envs

# Environments
.venv/
__pycache__/
*.pyc
.env

# Data & Assets (Heavy)
data/
lib/soundfonts/
*.wav
*.sf2
*.midi
*.zip
*.tar.bz2

# IDE & OS
.DS_Store
.vscode/
.idea/

# Logs & Temp
*.log
data/temp/

# Test harness artifacts (F0-T9b)
.pytest_cache/
.hypothesis/
.coverage
htmlcov/
.mutmut-cache
mutants/

# Vendored render toolchain & SFZ assets (F0-T2b) — heavy, re-fetchable.
# The manifest vendor/README.md is tracked; everything else is ignored.
/vendor/*
!/vendor/README.md

# Audition renders (F0-T2b) — aural proof material, re-generatable.
/audition/

# F0-T4b — training artefacts (checkpoints, JSON/BIN exports). Re-generatable
# from the deterministic training run; the L3 Ocular Proof JSONs under
# docs/gates/L3_OCULAR_PROOF/ are the durable artefacts.
/artifacts/
/logs/

# C++ build output — only the source + CMakeLists.txt is tracked.
/cpp/*/build/
